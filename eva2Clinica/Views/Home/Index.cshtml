@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mt-5">
    <h1 class="display-4 text-primary fw-bold">Bienvenido a Clínica Web</h1>
    <p class="lead">Tu salud es nuestra prioridad. Contamos con los mejores profesionales e infraestructura.</p>
    <hr class="my-4" />
    <p>Gestiona tus horas, revisa nuestras especialidades o contáctanos de manera rápida y segura.</p>
    
    <div class="mt-4">
        <a asp-action="Especialidades" class="btn btn-primary btn-lg me-2">Ver Especialidades</a>
        <a asp-action="Contacto" class="btn btn-outline-secondary btn-lg">Contáctanos</a>
    </div>
</div>