@model eva2Clinica.Models.Paciente

@{
    ViewData["Title"] = "Eliminar Paciente";
}

<div class="container mt-4">
    <h2 class="text-danger">Eliminar Paciente</h2>
    <hr />

    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">¡Atención!</h4>
        <p>¿Estás seguro que deseas eliminar el registro de <strong>@Model.NombreCompleto</strong>?</p>
        <hr>
        <p class="mb-0">Esta acción no se puede deshacer y los datos se borrarán permanentemente de la base de datos.</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">RUT</dt>
                <dd class="col-sm-9">@Model.Rut</dd>

                <dt class="col-sm-3">Teléfono</dt>
                <dd class="col-sm-9">@Model.Telefono</dd>

                <dt class="col-sm-3">Correo</dt>
                <dd class="col-sm-9">@Model.Correo</dd>

                <dt class="col-sm-3">Diagnóstico</dt>
                <dd class="col-sm-9">@Model.Diagnostico</dd>
            </dl>

            <form asp-action="Eliminar" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-danger">Sí, Eliminar Permanentemente</button>
            </form>
        </div>
    </div>
</div>