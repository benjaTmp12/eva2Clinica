<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clínica Salud</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>

    <header>
        <nav class="navbar">
            <div class="logo">🏥 Clínica Salud</div>
            <ul class="nav-links">
                <li><a asp-page="/Index">Inicio</a></li>
                <li><a asp-page="/Especialidades">Especialidades</a></li>
                <li><a asp-page="/Contacto">Contacto</a></li>
                <li><a asp-page="/Login" class="btn-login">Iniciar Sesión</a></li>
            </ul>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <p>&copy; 2026 Clínica Salud. Todos los derechos reservados.</p>
    </footer>

</body>
</html>
